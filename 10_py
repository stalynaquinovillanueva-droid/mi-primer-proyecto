# Simulador de cajero
saldo = 1000
clave_correcta = "1234"

print("=== CAJERO AUTOMÁTICO ===")
clave = input("Ingresa tu clave: ")

if clave != clave_correcta:
    print("❌ Clave incorrecta. Acceso denegado.")
else:
    print(f"\n✅ Bienvenido!")
    print(f"💰 Saldo actual: S/. {saldo}")
    
    monto = float(input("\n¿Cuánto deseas retirar? S/. "))
    
    if monto > saldo:
        print("❌ Saldo insuficiente")
    elif monto <= 0:
        print("❌ Monto no válido")
    else:
        saldo -= monto
        print(f"✅ Retiro exitoso de S/. {monto}")
        print(f"💰 Saldo restante: S/. {saldo}")